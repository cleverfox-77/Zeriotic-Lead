# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATE ONLY — this file is committed to a PUBLIC repo.
# Never put real values here. Real values go in .env (gitignored) and in the
# Vercel dashboard: Settings → Environment Variables. Redeploy after changing.
# ─────────────────────────────────────────────────────────────────────────────

# Neon Postgres connection string (pooled endpoint)
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Google Maps key — needs Places API (New) + Geocoding API, with billing.
# Server-side only: this is NEVER sent to the browser.
GOOGLE_MAPS_API_KEY=

# Shared password your employees type to log in.
TEAM_PASSWORD=

# Signs session tokens. MUST be long and random — a short one can be brute-forced
# to forge logins. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Email reports ────────────────────────────────────────────────────────────
# Gmail: turn on 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords and use it as SMTP_PASS.
# Your normal Google password will NOT work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Where reports are sent (the manager).
MANAGER_EMAIL=

# Guards the weekly cron route so strangers can't trigger report emails.
# Generate the same way as SESSION_SECRET.
CRON_SECRET=

# ── Social lookup (finds Facebook/Instagram pages) ───────────────────────────
# NOTE: Google Custom Search JSON API is CLOSED to new Cloud projects (any new
# key returns 403 forbidden however it's configured), and Brave retired its free
# tier in early 2026. Both are dead ends — don't spend time on them.
#
# Tavily: 1,000 free credits per month, RESETS monthly, no card. Spent first.
# https://tavily.com
TAVILY_API_KEY=

# Serper: 2,500 free credits, then ~$1 per 1,000 (~$0.06 per 60-lead scan).
# Used automatically once Tavily's monthly free quota is gone. https://serper.dev
SERPER_API_KEY=

# Switch from Tavily to Serper at this many Tavily queries per month.
TAVILY_MONTHLY_LIMIT=1000

# ── AI caller (Vapi hosts the calls) ─────────────────────────────────────────
# 1. vapi.ai → create account → API key.
# 2. Buy a Twilio number (~$1/mo) and import it into Vapi (or buy a Vapi number),
#    then copy its Phone Number ID from the Vapi dashboard.
# 3. Generate the webhook secret like SESSION_SECRET — Vapi echoes it back so
#    only Vapi can post call reports to us.
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=

# ElevenLabs — voice cloning (Starter plan $5/mo includes instant cloning).
# Optional: ELEVENLABS_DEFAULT_VOICE_ID is the stock voice before anyone trains.
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_v3

# Anthropic — powers "Improve from my calls" (pennies per run). Optional.
ANTHROPIC_API_KEY=

# Safety caps (defaults shown). All enforced server-side.
AI_CALL_MONTHLY_BUDGET=50
AI_CALL_DAILY_MAX=15
AI_CALL_MAX_MINUTES=8

# Optional overrides while tuning Banglish quality — raw JSON passed to Vapi.
# e.g. VAPI_TRANSCRIBER_JSON={"provider":"deepgram","model":"nova-3","language":"multi"}
VAPI_TRANSCRIBER_JSON=
VAPI_VOICE_JSON=
VAPI_MODEL_JSON=

# ── WhatsApp portfolio sending (Meta Cloud API) ──────────────────────────────
# Needs: Meta Business verification, a WhatsApp Business number (NOT one already
# used in the WhatsApp app), and ONE approved template with a DOCUMENT header
# and a {{1}} body variable. Until configured, the AI logs "send manually"
# notes instead — calls still work.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_TEMPLATE_BODY_VARS=1
# Public URL of your portfolio PDF (attach it to the template header).
PORTFOLIO_URL=

# Optional: canonical app URL for Vapi webhooks (defaults to the request host).
APP_URL=
