# Neon Postgres connection string (pooled endpoint)
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Google Maps key — Places API (New) + Geocoding API enabled, with billing.
# Server-side only: this is NEVER sent to the browser.
GOOGLE_MAPS_API_KEY=

# Shared password your employees type to log in.
TEAM_PASSWORD=

# Random string used to sign session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
