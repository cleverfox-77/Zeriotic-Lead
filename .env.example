# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATE ONLY — this file is committed to a PUBLIC repo.
# Never put real values here. Real values go in .env (gitignored) and in the
# Vercel dashboard: Settings → Environment Variables. Redeploy after changing.
# ─────────────────────────────────────────────────────────────────────────────

# Neon Postgres connection string (pooled endpoint)
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Google Maps key — needs Places API (New) + Geocoding API, with billing.
# Server-side only: this is NEVER sent to the browser.
GOOGLE_MAPS_API_KEY=

# Shared password your employees type to log in.
TEAM_PASSWORD=

# Signs session tokens. MUST be long and random — a short one can be brute-forced
# to forge logins. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Email reports ────────────────────────────────────────────────────────────
# Gmail: turn on 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords and use it as SMTP_PASS.
# Your normal Google password will NOT work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Where reports are sent (the manager).
MANAGER_EMAIL=

# Guards the weekly cron route so strangers can't trigger report emails.
# Generate the same way as SESSION_SECRET.
CRON_SECRET=
