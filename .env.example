# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATE ONLY — this file is committed to a PUBLIC repo.
# Never put real values here. Real values go in .env (gitignored) and in the
# Vercel dashboard: Settings → Environment Variables. Redeploy after changing.
# ─────────────────────────────────────────────────────────────────────────────

# Neon Postgres connection string (pooled endpoint)
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Google Maps key — needs Places API (New) + Geocoding API, with billing.
# Server-side only: this is NEVER sent to the browser.
GOOGLE_MAPS_API_KEY=

# Shared password your employees type to log in.
TEAM_PASSWORD=

# Signs session tokens. MUST be long and random — a short one can be brute-forced
# to forge logins. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Email reports ────────────────────────────────────────────────────────────
# Gmail: turn on 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords and use it as SMTP_PASS.
# Your normal Google password will NOT work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Where reports are sent (the manager).
MANAGER_EMAIL=

# Guards the weekly cron route so strangers can't trigger report emails.
# Generate the same way as SESSION_SECRET.
CRON_SECRET=

# ── Social lookup (finds Facebook/Instagram pages) ───────────────────────────
# Google Custom Search. Needs BOTH:
#   1. An API key with the "Custom Search API" enabled in Google Cloud.
#   2. A search engine ID (cx) from https://programmablesearchengine.google.com
#      with facebook.com and instagram.com added under "Sites to search".
#      You do NOT need "Search the entire web" — restricting the engine to those
#      two sites is what we want, since every other result is discarded anyway.
# Free: 100 queries/day, then $5/1,000 (~$0.30 per 60-lead scan).
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# OPTIONAL. Brave is tried first when set, to spend its free quota before
# Google's. Note Brave requires a payment method on file even for the $0 tier,
# so leaving this blank is fine — the app just uses Google.
# Free tier: 2,000 queries/month, 1 query/second.
BRAVE_SEARCH_API_KEY=

# Switch from Brave to Google at this many Brave queries per month.
BRAVE_MONTHLY_LIMIT=1900
